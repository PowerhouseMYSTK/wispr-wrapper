{
  "name": "wispr-wrapper",
  "version": "1.0.3",
  "description": "Electron web wrapper with Next.js toolbar UI",
  "main": "electron/dist/main.js",
  "scripts": {
    "postinstall": "node scripts/create-placeholder-icon.js",
    "dev": "tsc -p tsconfig.electron.json && concurrently --kill-others \"next dev --turbopack -p 3131\" \"wait-on http://localhost:3131 && cross-env NODE_ENV=development electron .\"",
    "build": "next build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "pack": "npm run build && electron-builder --dir",
    "start": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.wispr.wrapper",
    "productName": "Wispr Wrapper",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/dist/**/*",
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/mint.jpg",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/mint.jpg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/mint.jpg",
      "category": "Network"
    },
    "publish": {
      "provider": "github",
      "owner": "PowerhouseMYSTK",
      "repo": "wispr-wrapper"
    }
  }
}
